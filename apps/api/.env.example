# Local development uses the docker-compose Postgres (see repo-root docker-compose.yml).
# Both URLs point at the same local DB; the split matters only for Neon in prod.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"

# Comma-separated browser origins allowed by CORS.
WEB_ORIGIN="http://localhost:3000"

# PORT is injected by the host (Railway/Render) in prod; defaults to 3001 locally.
# PORT=3001

# FRED (St. Louis Fed) — free key from https://fredaccount.stlouisfed.org. Server-only.
FRED_API_KEY=
# Finnhub — free key from https://finnhub.io/register. Server-only.
FINNHUB_API_KEY=
# Optional: override ingestion cadence / poll interval.
# FRED_CRON="0 2 * * *"
# MARKET_POLL_SECONDS=60

# NewsAPI (newsapi.org) — market news search. Free tier ~100 req/day. Server-only.
NEWSAPI_KEY=
