# Base URL of the Nest.js API (apps/api).
# Local dev default below; in Vercel set this to your Railway/Render API URL.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Hosted answer backend for the tl;dr console (/api/ask).
# Any OpenAI-compatible /chat/completions endpoint works.
# Default below = Ollama Cloud free tier. Server-only — never NEXT_PUBLIC_.
ASK_BASE_URL=https://ollama.com/v1
ASK_MODEL=gpt-oss:120b
ASK_API_KEY=

# Optional: lock the proxy to your site origin (best-effort abuse guard).
# ASK_ALLOWED_ORIGIN=https://alek-contact.com
